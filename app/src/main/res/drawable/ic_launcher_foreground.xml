<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#00d9ff"/>
            <size android:width="64dp" android:height="64dp"/>
        </shape>
    </item>
    <item android:gravity="center" android:left="20dp" android:top="20dp" android:right="20dp" android:bottom="20dp">
        <bitmap android:src="@android:drawable/ic_media_play" android:gravity="center"/>
    </item>
</layer-list>
