<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎙️ 播客APP"
        android:textSize="24sp"
        android:textColor="#fff"
        android:gravity="center"
        android:padding="20dp"
        android:background="linear-gradient(135deg, #667eea 0%, #764ba2 100%)" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213e"
        android:padding="20dp"
        android:layout_margin="15dp"
        android:gravity="center">

        <ImageView
            android:id="@+id/coverImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择一期节目开始播放"
            android:textSize="18sp"
            android:textColor="#fff"
            android:layout_marginTop="15dp" />

        <TextView
            android:id="@+id/authorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="14sp"
            android:textColor="#aaa"
            android:layout_marginTop="5dp" />

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:progressTint="#667eea"
            android:thumbTint="#667eea" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <Button
                android:id="@+id/rewindButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="⏪"
                android:background="#667eea"
                android:textColor="#fff" />

            <Button
                android:id="@+id/playButton"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:text="▶"
                android:textSize="24sp"
                android:background="#667eea"
                android:textColor="#fff"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp" />

            <Button
                android:id="@+id/forwardButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="⏩"
                android:background="#667eea"
                android:textColor="#fff" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📻 示例节目"
        android:textSize="18sp"
        android:textColor="#667eea"
        android:paddingStart="15dp"
        android:paddingTop="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="15dp" />

</LinearLayout>